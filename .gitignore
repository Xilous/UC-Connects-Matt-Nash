# Visual Studio / .NET gitignore

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# NuGet packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# MSBuild / build artifacts
*.dll
*.pdb
*.exe
*.cache
*.tlog

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Misc
*.tmp
*.bak
Thumbs.db
ehthumbs.db
Desktop.ini
