<Window x:Class="PM_Project_Tracking.TransferAddUserMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:staticData="clr-namespace:PM_Project_Tracking"
        Title="USER CREATION MENU" Height="280" Width="320">
    <Window.Resources>
        <staticData:PermissionTier x:Key="PermissionTier" />
        <staticData:CompanyId x:Key="CompanyId" />
    </Window.Resources>
    <Grid Background="#FF494949">
        <StackPanel Name="StckPan_UserSP" Orientation="Vertical" Margin="0,10,0,0" >
            <StackPanel Orientation="Horizontal">
                <Label Margin="10,5,5,5" Content="NAME" Width="130" Foreground="White"/>
                <TextBox Name="TB_DomainUserName" Margin="0,5,0,5" Width="140"  
                          />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="10,5,5,5" Content="PERMISSIONS TIER" Width="130" Foreground="White"/>
                <ComboBox Name="CBox_PermissionTier" Margin="0,5,0,5" Width="140" 
                          ItemsSource="{Binding Source={StaticResource PermissionTier}}" 
                          />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="10,5,5,5" Content="COMPANY ID" Width="130" Foreground="White"/>
                <ComboBox Name="CBox_CompanyId" Margin="0,5,0,5" Width="140" 
                          ItemsSource="{Binding Source={StaticResource CompanyId}}" 
                          />
            </StackPanel>
            <!--<StackPanel Orientation="Horizontal">
                <Label Margin="10,5,5,5" Content="GP MANAGER NAME" Width="130" Foreground="White"/>
                <TextBox Name="TB_GPManagerName" Margin="0,5,0,5" Width="140"  
                         />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="10,5,5,5" Content="GP ESTIMATOR NAME" Width="130" Foreground="White"/>
                <TextBox Name="TB_GPEstimatorName" Margin="0,5,0,5" Width="140" 
                         />
            </StackPanel>-->
            <StackPanel Orientation="Horizontal">
                <Label Margin="10,5,5,5" Content="EMAIL" Width="130" Foreground="White"/>
                <TextBox Name="TB_UserEmail" Margin="0,5,0,5" Width="140"  
                          />
            </StackPanel>

            <Button Name="BTN_AddUser" Content="ADD USER" Margin="105,15,5,5" Height="20" Width="120" Click="BTN_AddUser_Click"  />
            <Rectangle Margin="0,15,0,0" Height="2" Width="250" VerticalAlignment="Top" HorizontalAlignment="Center" Fill="LightGray" Opacity="0.3" />
        </StackPanel>
    </Grid>
</Window>
