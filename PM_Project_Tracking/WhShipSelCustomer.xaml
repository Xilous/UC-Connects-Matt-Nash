<Window x:Class="PM_Project_Tracking.WhShipSelCustomer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhShipCustomerSelect" Height="600" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel Orientation="Vertical">
                <Label Content="SEARCH RTLORD NUMBER" Margin="10,10,0,0" Foreground="White" />
                <TextBox Name="TB_RtlOrdSearch" Margin="10,10,0,0" Width="120" HorizontalAlignment="Left" TextChanged="TB_RtlOrdSearch_TextChanged" />
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_RtlOrdList"
                                                                                                      
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single" MouseDoubleClick="DG_RtlOrdList_MouseDoubleClick"  >
            <DataGrid.Columns>
                <DataGridTextColumn Header="RTL ORDER" Binding="{Binding SopNumber}" Width="120">

                </DataGridTextColumn>
                <DataGridTextColumn Header="CUSTOMER NAME" Binding="{Binding CustomerName}" Width="*">

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
