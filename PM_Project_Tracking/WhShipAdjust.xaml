<Window x:Class="PM_Project_Tracking.WhShipAdjust"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PM_Project_Tracking"
        mc:Ignorable="d"
        Title="WhShipAdjust" Height="500" Width="1200">
    <Grid Background="#FF494949" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="960"/>
            <ColumnDefinition Width="160" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Width="160" Orientation="Vertical" >
                    <Label Content="SHIP MEMO NUMBER" Foreground="White" HorizontalAlignment="Center" />
                    <TextBox Name="TB_MemoNumber" Width="120" HorizontalAlignment="Center" TextChanged="TB_MemoNumber_TextChanged" />
                </StackPanel>
                <StackPanel Margin="0,10,10,0" >
                    <DataGrid Name="DG_MemoNumList"
                              Width="150"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            RowHeaderWidth="0"
                            ColumnHeaderHeight="45"
                            VirtualizingStackPanel.IsVirtualizing="True" 
                            VirtualizingStackPanel.VirtualizationMode="Recycling"
                            SelectionMode="Single" 
                              
                              MouseDoubleClick="DG_MemoNumList_MouseDoubleClick"
                              >
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MEMO NUMBER" Binding="{Binding SingleValue}" Width="150"  IsReadOnly="True">

                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition />

            </Grid.RowDefinitions>
            <Grid Grid.Row="0" >

            <DataGrid  Name="DG_ShipLineList"                                                                                     
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single" MouseDoubleClick="DG_ShipLineList_MouseDoubleClick"   >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PO NUMBER" Binding="{Binding PoNumber}" Width="80" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SOP NUMBER" Binding="{Binding PoNumber}" Width="80" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="INDEX" Binding="{Binding Polnenum}" Width="80" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="JOB NUMBER" Binding="{Binding JobNumber}" Width="90" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ITEM NUMBER" Binding="{Binding ItemNumber}" Width="120" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ITEM DESCRIPTION" Binding="{Binding ItemDescription}" Width="*" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ORIG. ORDER QUANTITY" Binding="{Binding QuantityOrdered}" Width="80" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SHIP QUANTITY" Binding="{Binding QuantityShipped}" Width="80" IsReadOnly="True" >

                    </DataGridTextColumn>
                        <DataGridTemplateColumn Header="DELETE" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" Click="Button_Click"

                                                    />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            
        </Grid>
        <Grid Grid.Column="2" Visibility="Hidden" >
            <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center">
                <TextBlock Name="TBLCK_SeletedItem" Margin="15,0,10,0" Height="40" Foreground="White" >

                </TextBlock>
                <Label Content="ORIGINAL QUANTITY" Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="White" />
                <Label Name="LBL_OriginalQuantity" Width="30" Height="30" HorizontalAlignment="Center" VerticalContentAlignment="Center" Foreground="white" />
                <Label Content="NEW QUANTITY" HorizontalAlignment="Center" Foreground="white" />
                <TextBox Name="TB_NewQuantity" Width="120" HorizontalAlignment="Center" Foreground="White" />
                <Button Name="BTN_CommitChanges" Content="UPDATE" Margin="0,10,0,0" Width="100" HorizontalAlignment="Center" Click="BTN_CommitChanges_Click" />
            </StackPanel>

        </Grid>
    </Grid>
</Window>
