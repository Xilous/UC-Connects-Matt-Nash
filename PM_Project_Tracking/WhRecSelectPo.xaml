<Window x:Class="PM_Project_Tracking.WhRecSelectPo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:staticData="clr-namespace:PM_Project_Tracking"
        Title="WhRetrievePo" Height="600" Width="700" Closed="Window_Closed">
    <Window.Resources>
        <staticData:DoNotShipConverter x:Key="DoNotShipConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel Orientation="Vertical">
                <Label Content="SEARCH PO NUMBER" Margin="10,10,0,0" Foreground="White" />
                <TextBox Name="TB_PoSearch" Margin="10,10,0,0" Width="120" HorizontalAlignment="Left" TextChanged="TB_PoSearch_TextChanged"/>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_PoHeaderList"
                                                                                                      
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single" MouseDoubleClick="DG_PoHeaderList_MouseDoubleClick" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="PO NUMBER" Binding="{Binding PoNumber}" Width="100" IsReadOnly="True">
                    
                </DataGridTextColumn>
                <DataGridTextColumn Header="JOB NUMBER" Binding="{Binding JobNumber}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
                <!--<DataGridTextColumn Header="DO NOT SHIP BEFORE DATE" Width="100" Binding="{Binding DoNotShipBeforeDate, StringFormat=\{0:dd \MMM \yyyy\}}" IsReadOnly="True">

                </DataGridTextColumn>-->
                <DataGridTextColumn  
                    Header="DO NOT SHIP BEFORE DATE"
                    MinWidth="100" MaxWidth="1000"
                    x:Name="ProductName"
                    Binding="{Binding DoNotShipBeforeDate, StringFormat=\{0:dd \MMM \yyyy\}}"
                    IsReadOnly="True" 
                    >
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="TextBlock.Background" Value="{Binding DoNotShipBeforeDate, Converter={StaticResource DoNotShipConverter}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>

                </DataGridTextColumn>
                <DataGridTextColumn Header="JOB NAME" Binding="{Binding JobName}" Width="300" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="BUYER ID" Binding="{Binding BuyerId}" Width="*" IsReadOnly="True">

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
