<Window x:Class="PM_Project_Tracking.TransferBidMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TransferProjectMenu" Height="600" Width="400">
    <Grid Background="#FF494949">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Label Content="Only projects that have been created in GP and are found in the &#10;'All Projects' menu will show up in the list below." Height="60" Foreground="White"/>
        </Grid>
        <Grid Grid.Row="1">
            <DataGrid Name="DG_EligibleProjList"
                AutoGenerateColumns="False"
                CanUserSortColumns="False"
                CanUserAddRows="False"
                RowHeaderWidth="0"
                ColumnHeaderHeight="45"
                VirtualizingStackPanel.IsVirtualizing="True" 
                VirtualizingStackPanel.VirtualizationMode="Recycling"
                CanUserDeleteRows="True"
                SelectionMode="Single" MouseDoubleClick="DG_EligibleProjList_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PROJECT NUMBER" Width="85" Binding="{Binding JobNumber}" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PROJECT NAME" Width="*" Binding="{Binding JobName}" IsReadOnly="True" >

                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
