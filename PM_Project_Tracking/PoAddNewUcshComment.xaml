<Window x:Class="PM_Project_Tracking.PoAddNewUcshComment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PoAddNewUcshComment" Height="800" Width="800" Closed="Window_Closed">
    <Grid Background="#FF494949">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Vertical">
                <Label Name="LBL_PoNumber" Foreground="White"/>
                <Label Name="LBL_ItemDescription" Foreground="White"/>
                <Label Name="LBL_HeaderLineTitle" Foreground="White"/>
                <Button Name="BTN_NewComment" Content="ADD NEW COMMENT" Width="140" HorizontalAlignment="Left" Click="BTN_NewComment_Click"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <DataGrid Name="DG_HeaderCommentList" 
                    FrozenColumnCount="1"                                  
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    ColumnHeaderHeight="45"
                    VirtualizingStackPanel.IsVirtualizing="True" 
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    SelectionMode="Single"  >
                <DataGrid.Resources>
                    <Style TargetType="{x:Type DataGridCell}" >
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                            SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DG_HeaderCommentList_PreviewMouseLeftButtonDown"></EventSetter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Width="40" Binding="{Binding Id}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="USER" Width="80" Binding="{Binding CreatingUser}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DATE" Width="80" Binding="{Binding DateCreated, StringFormat=\{0:dd \MMM \yyyy\}}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="DO NOT SHIP BEFORE DATE">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DoNotShipBeforeDate}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding DoNotShipBeforeDate}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="COMMENT" Width="*" Binding="{Binding CommentText}" >

                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
            <DataGrid Name="DG_LineCommentList" 
                    FrozenColumnCount="1"                                  
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    ColumnHeaderHeight="45"
                    VirtualizingStackPanel.IsVirtualizing="True" 
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    SelectionMode="Single"  >
                <DataGrid.Resources>
                    <Style TargetType="{x:Type DataGridCell}" >
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                            SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DG_HeaderCommentList_PreviewMouseLeftButtonDown"></EventSetter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Width="40" Binding="{Binding Id}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="USER" Width="80" Binding="{Binding CreatingUser}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DATE" Width="80" Binding="{Binding DateCreated, StringFormat=\{0:dd \MMM \yyyy\}}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="COMMENT" Width="*" Binding="{Binding CommentText}" >

                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
