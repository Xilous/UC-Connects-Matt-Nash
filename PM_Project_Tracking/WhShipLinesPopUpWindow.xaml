<Window x:Class="PM_Project_Tracking.WhShipLinesPopUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhRecSelectPoLines" Height="900" Width="1000" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="500" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel  Name="StckPan_Warehouse_Shipping_JobProperties" Margin="0,20,0,0" Orientation="Horizontal" Visibility="Hidden">
                <StackPanel Orientation="Vertical" >
                    <Label x:Name="LBL_WH_Rec_JobNumber" Content="JOB NUMBER" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_JobName" Content="JOB NAME" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Courier" Content="COURIER" Margin="0,12,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Shipper" Content="SHIPPER" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ActualShipDate" Content="ACTUAL SHIP DATE" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Waybill" Content="WAYBILL" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <!--<Label x:Name="LBL_WH_ReschShipDate" Content="RESCHED SHIP DATE" Foreground="White" Width="120" />-->
                    <Label x:Name="LBL_WH_Rec_ReqShipdate" Content="REQ. SHIP DATE" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ShipToName" Content="SHIP TO NAME" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Address1" Content="ADDRESS 1" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Address2" Content="ADDRESS 2" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_City" Content="CITY" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Province" Content="PROVINCE" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_PostalCode" Content="POSTAL CODE" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Country" Content="COUNTRY" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Phone" Content="PHONE" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Fax" Content="FAX" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ShipMethod" Content="SHIP METHOD" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Notes" Content="NOTES" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                </StackPanel>
                <StackPanel Orientation="Vertical" >
                    <TextBox Name="TB_WH_Rec_JobNumber" Text="{Binding JobNumber, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="{Binding ElementName=LBL_WH_Rec_JobName, Path=Width}"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_JobNumber, Path=Margin}" IsReadOnly="True"/>
                    <TextBox Name="TB_WH_Rec_JobName" Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_JobName, Path=Margin}" IsReadOnly="True"/>
                    <TextBox Name="TB_WH_Rec_Courier" Text="{Binding Courier, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Courier, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Shipper" Text="{Binding Shipper, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Shipper, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ActualShipDate" Text="{Binding ActualShipDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ActualShipDate, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Waybill" Text="{Binding Waybill, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Waybill, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ReqShipDate" Text="{Binding ReqShipDate, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ReqShipdate, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ShipToName" Text="{Binding ShipToName,  UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ShipToName, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Address1" Text="{Binding Address1, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Address1, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Address2" Text="{Binding Address2, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Address2, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_City" Text="{Binding ReqShipDate, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_City, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Province" Text="{Binding ProvState, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_City, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_PostalCode" Text="{Binding PostalZip, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_PostalCode, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Country" Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Country, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Phone" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Phone, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Fax" Text="{Binding FaxNumber, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Fax, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ShipMethod" Text="{Binding ShipMethod, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ShipMethod, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Notes" Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="80" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Notes, Path=Margin}" />
                </StackPanel>
            </StackPanel>
            <StackPanel  Name="StckPan_Warehouse_Shipping_CustProperties" Margin="0,20,0,0" Orientation="Horizontal" >
                <StackPanel Orientation="Vertical" >
                    <Label x:Name="LBL_WH_Rec_SopNumber" Content="RTLORD" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_RtlCustomerName" Content="CUSTOMER NAME" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_CourierCust" Content="COURIER" Margin="0,12,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ShipperCust" Content="SHIPPER" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ActualShipDateCust" Content="ACTUAL SHIP DATE" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_WaybillCust" Content="WAYBILL" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <!--<Label x:Name="LBL_WH_ReschShipDate" Content="RESCHED SHIP DATE" Foreground="White" Width="120" />-->
                    <Label x:Name="LBL_WH_Rec_ReqShipdateCust" Content="REQ. SHIP DATE" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ShipToNameCust" Content="SHIP TO NAME" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Address1Cust" Content="ADDRESS 1" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_Address2Cust" Content="ADDRESS 2" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_CityCust" Content="CITY" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ProvinceCust" Content="PROVINCE" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_PostalCodeCust" Content="POSTAL CODE" Margin="0,2,0,0" Width="120" Height="21" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_CountryCust" Content="COUNTRY" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_PhoneCust" Content="PHONE" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_FaxCust" Content="FAX" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_ShipMethodCust" Content="SHIP METHOD" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                    <Label x:Name="LBL_WH_Rec_NotesCust" Content="NOTES" Margin="0,2,0,0" Width="120" Height="20" HorizontalContentAlignment="Left" Padding="5,2,2,0" Foreground="White" />
                </StackPanel>
                <StackPanel Orientation="Vertical" >
                    <TextBox Name="TB_WH_Rec_SopNumber" Text="{Binding SopNumber, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="{Binding ElementName=LBL_WH_Rec_JobName, Path=Width}"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_JobNumber, Path=Margin}" IsReadOnly="True"/>
                    <TextBox Name="TB_WH_Rec_CustomerName" Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_JobName, Path=Margin}" IsReadOnly="True"/>
                    <TextBox Name="TB_WH_Rec_CourierCust" Text="{Binding Courier, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Courier, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ShipperCust" Text="{Binding Shipper, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Shipper, Path=Margin}" />
                    <!--<TextBox Name="TB_WH_Rec_ActualShipDateCust" Text="{Binding ActualShipDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ActualShipDate, Path=Margin}" />-->

                    <DatePicker Name="TB_WH_Rec_ActualShipDateCust" Text="{Binding ActualShipDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="25" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ActualShipDate, Path=Margin}" />

                    <TextBox Name="TB_WH_Rec_WaybillCust" Text="{Binding Waybill, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Waybill, Path=Margin}" />
                    <!--<TextBox Name="TB_WH_Rec_ReqShipDateCust" Text="{Binding ReqShipDate, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ReqShipdate, Path=Margin}" />-->

                    <DatePicker Name="TB_WH_Rec_ReqShipDateCust" Text="{Binding ReqShipDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                             Width="240"
                                                             Height="25" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ReqShipdate, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ShipToNameCust" Text="{Binding ShipToName, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ShipToName, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Address1Cust" Text="{Binding Address1, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Address1, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_Address2Cust" Text="{Binding Address2, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Address2, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_CityCust" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_City, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ProvinceCust" Text="{Binding ProvState, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_City, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_PostalCodeCust" Text="{Binding PostalZip, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_PostalCode, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_CountryCust" Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Country, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_PhoneCust" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Phone, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_FaxCust" Text="{Binding FaxNumber, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Fax, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_ShipMethodCust" Text="{Binding ShipMethod, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="20" HorizontalAlignment="Left"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_ShipMethod, Path=Margin}" />
                    <TextBox Name="TB_WH_Rec_NotesCust" Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="240"
                                                             Height="80" HorizontalAlignment="Left"
                                                             AcceptsReturn="True"
                                                             Margin="{Binding ElementName=LBL_WH_Rec_Notes, Path=Margin}" />
                </StackPanel>

            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_ShipLineList"
                                                                                                      
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single"   >
            <DataGrid.Columns>
                <DataGridTextColumn Header="PO NUMBER" Binding="{Binding PoNumber}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="SOP NUMBER" Binding="{Binding PoNumber}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="INDEX" Binding="{Binding Polnenum}" Width="80" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="JOB NUMBER" Binding="{Binding JobNumber}" Width="90" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="ITEM NUMBER" Binding="{Binding ItemNumber}" Width="120" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="ITEM DESCRIPTION" Binding="{Binding ItemDescription}" Width="*" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="ORIG. ORDER QUANTITY" Binding="{Binding QuantityOrdered}" Width="80" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="SHIP QUANTITY" Binding="{Binding QuantityShipped}" Width="80" IsReadOnly="True" >

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
