<Window x:Class="PM_Project_Tracking.ProjectManagementWindows.ProgressBillingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:staticDataTwo="clr-namespace:PM_Project_Tracking.ProjectManagementClasses"
        xmlns:staticDataThree="clr-namespace:PM_Project_Tracking.ProjectManagementWindows"
        Title="ProgressBillingWindow"  Height="900" Width="1400" Closing="Window_Closing" >
    <Window.Resources>

        <staticDataTwo:CostCodeDropDowns x:Key="CostCodeDropDowns" />
        <staticDataThree:StatusToColor x:Key="StatusToColor" />      
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border Name="Border" Background="{StaticResource BackgroundBrush}">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2,12,2" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#FF494949">
        <TabControl TabStripPlacement="Top" Background="#FF494949" Foreground="White" >

            <TabItem Header="BASE CONTRACT" Background="#FF494949" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" >
                        <StackPanel Orientation="Vertical">
                            <StackPanel Name="StckPan_AddRegularLine">
                                <Rectangle Margin="0,12,0,0" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                                <StackPanel Margin="5,10,0,0" Orientation="Vertical">
                                    <Label Content="COST CODE" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                                    <StackPanel Orientation="Vertical">
                                        <ComboBox Name="CBox_CostCode" Margin="0,2,0,10" Width="240" HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                        ItemsSource="{Binding Source={StaticResource CostCodeDropDowns}}"
                                        SelectedItem="{Binding Path=CostCodeType}" 
                                        SelectedValue="{Binding Path=CostCodeType.CostCode}"
                                        SelectedValuePath="CostCode" 
                                        
                                        >
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} - {1}">
                                                                <Binding Path="CostCode"/>
                                                                <Binding Path="Description"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Label Name="LBL_CostCodeDescription" Margin="10,-8,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                                    </StackPanel>
                                    <StackPanel>

                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Name="BTN_AddRegularLine" Margin="0,2,10,0" Content="ADD" Height="20" Width="100" Click="BTN_AddRegularLine_Click"   />
                                        <!--<Button Name="BTN_ClearRegularLines" Margin="0,2,10,0" Content="CLEAR" Height="20" Width="100" Click="BTN_ClearRegularLines_Click"    />-->
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <!--<Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />-->
                                <!--<Button Name="BTN_CreateRevision" Content="REVISION" Margin="0,0,0,0" Height="20" Width="100" HorizontalAlignment="Center" />
                    <Button Name="BTN_CancelQuote" Content="CANCEL" Margin="0,10,0,0" Height="20" Width="100" HorizontalAlignment="Center" />-->
                                <!--<Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                                <Button Name="BTN_AddHwFromSchedule" Content="ADD HARDWARE FROM SCHEDULE" Margin="0,0,0,0" Height="20" Width="200" HorizontalAlignment="Center" />-->
                                <Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                                <Button Name="BTN_RegularLines_UpdateServer" Content="UPDATE" Margin="0,0,0,0" Height="20" Width="100" HorizontalAlignment="Center" Click="BTN_RegularLines_UpdateServer_Click" />
                                <Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid>
                            <DataGrid Name="DG_BaseContractLines"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      RowHeaderWidth="0"
                                      ColumnHeaderHeight="45"
                                      VirtualizingStackPanel.IsVirtualizing="True" 
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="DEL" Width="25" Binding="{Binding Path=IsDeleted, Mode=TwoWay}">

                                    </DataGridCheckBoxColumn>
                                    <DataGridTemplateColumn Header="MOD" Width="25" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Rectangle Fill="{Binding IsModified, Converter={StaticResource StatusToColor}}" Width="16" Height="16" Margin="0,2,5,2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="COST CODE" Width="80" Binding="{Binding CostCode}" IsReadOnly="True">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="HOLDBACK" Width="80" >

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="BASE CONTRACT BREAKDOWN" Binding="{Binding BaseDescription}"  Width="*" >

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="BASE CONTRACT" Binding="{Binding BaseContract, StringFormat=N2}"  Width="90" >

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="COMPLETED" Binding="{Binding CompletedAmount, StringFormat=N2}" Width="90" IsReadOnly="True">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="PREVIOUS" Binding="{Binding PreviousAmount, StringFormat=N2}"  Width="90" IsReadOnly="True">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="CURRENT" Binding="{Binding CurrentAmount, StringFormat=N2}"  Width="90" >
 
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="BALANCE" Binding="{Binding Balance, StringFormat=N2}" Width="90" IsReadOnly="True">

                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="APPROVED EXTRAS" Background="#FF494949" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" >
                        <StackPanel Orientation="Vertical">
                            <StackPanel Name="StckPan_AddChangeLine">
                                <Rectangle Margin="0,12,0,0" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                                <StackPanel Margin="5,10,0,0" Orientation="Vertical">
                                    <Label Content="COST CODE" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                                    <StackPanel Orientation="Vertical">
                                        <ComboBox Name="CBox_CostCodeChangeLine" Margin="0,2,0,10" Width="240" HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                        ItemsSource="{Binding Source={StaticResource CostCodeDropDowns}}"
                                        SelectedItem="{Binding Path=CostCodeType}" 
                                        SelectedValue="{Binding Path=CostCodeType.CostCode}"
                                        SelectedValuePath="CostCode" 
                                        
                                        
                                        >
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} - {1}">
                                                                <Binding Path="CostCode"/>
                                                                <Binding Path="Description"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Label Content="QUOTE NUMBER" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                                        <ComboBox Name="CBox_CostCodeQuoteNumber" Margin="0,2,0,10" Width="240" HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                        
                                        SelectedItem="{Binding Path=ChangeHeader}" 
                                        SelectedValue="{Binding Path=ChangeHeader.QuoteNumber}"
                                        SelectedValuePath="CostCode" 
                                        
                                        
                                        >
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} - {1}">
                                                                <Binding Path="QuoteNumber"/>
                                                                <Binding Path="HeaderDescription"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Label  Margin="10,-8,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                                    </StackPanel>
                                    <StackPanel>

                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Name="BTN_AddChangeLine" Margin="0,2,10,0" Content="ADD" Height="20" Width="100" Click="BTN_AddChangeLine_Click"   />
                                        <!--<Button Name="BTN_ClearChangeLines" Margin="0,2,10,0" Content="CLEAR" Height="20" Width="100" Click="BTN_ClearChangeLines_Click"    />-->
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <!--<Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />-->
                                <!--<Button Name="BTN_CreateRevision" Content="REVISION" Margin="0,0,0,0" Height="20" Width="100" HorizontalAlignment="Center" />
                    <Button Name="BTN_CancelQuote" Content="CANCEL" Margin="0,10,0,0" Height="20" Width="100" HorizontalAlignment="Center" />-->
                                <!--<Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                                <Button  Content="ADD HARDWARE FROM SCHEDULE" Margin="0,0,0,0" Height="20" Width="200" HorizontalAlignment="Center"   />-->
                                <Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                                <Button Name="BTN_ChangeLines_UpdateServer" Content="UPDATE" Margin="0,0,0,0" Height="20" Width="100" HorizontalAlignment="Center" Click="BTN_ChangeLines_UpdateServer_Click"  />
                                <Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Column="1">
                        <DataGrid Name="DG_ChangeLines"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      RowHeaderWidth="0"
                                      ColumnHeaderHeight="45"
                                      VirtualizingStackPanel.IsVirtualizing="True" 
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      SelectionMode="Single">
                            <DataGrid.Resources>
                                <Style TargetType="{x:Type DataGridCell}" >
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                            SnapsToDevicePixels="True">
                                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DG_ChangeLines_PreviewMouseLeftButtonDownShipRec"></EventSetter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="DEL" Width="25" Binding="{Binding Path=IsDeleted, Mode=TwoWay}">

                                </DataGridCheckBoxColumn>
                                <DataGridTemplateColumn Header="MOD" Width="25" >
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Rectangle Fill="{Binding IsModified, Converter={StaticResource StatusToColor}}" Width="16" Height="16" Margin="0,2,5,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="QUOTE NUMBER" Width="80" Binding="{Binding QuoteNumber}" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="CPOC" Width="80" Binding="{Binding Cpoc}" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="COST CODE" Width="80" Binding="{Binding CostCode}" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="HOLDBACK" Binding="{Binding HoldbackPercentage}" Width="80" >

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="CHANGE CONTRACT BREAKDOWN" Binding="{Binding BaseDescription}"  Width="*" >

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="BASE CONTRACT" Binding="{Binding BaseContract, StringFormat=N2}"  Width="90" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="COMPLETED" Binding="{Binding CompletedAmount, StringFormat=N2}" Width="90" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="PREVIOUS" Binding="{Binding PreviousAmount, StringFormat=N2}"  Width="90" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="CURRENT" Binding="{Binding CurrentAmount, StringFormat=N2}"  Width="90" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTextColumn Header="BALANCE" Binding="{Binding Balance, StringFormat=N2}" Width="90" IsReadOnly="True">

                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="DRAW DOWNS WINDOW" Width="60" HeaderStyle="{StaticResource SelectableColumn}" >
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="X"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="UNAPPROVED EXTRAS" Background="#FF494949" Foreground="White">

            </TabItem>
            <TabItem Header="SUPPLEMENTAL BREAKDOWN" Background="#FF494949" Foreground="White">

            </TabItem>
        </TabControl>
    </Grid>
</Window>
