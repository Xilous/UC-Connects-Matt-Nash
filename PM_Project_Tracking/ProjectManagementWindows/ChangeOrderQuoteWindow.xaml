<Window x:Class="PM_Project_Tracking.ProjectManagementWindows.ChangeOrderQuoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:staticData="clr-namespace:PM_Project_Tracking.ProjectManagementWindows"
        xmlns:staticDataTwo="clr-namespace:PM_Project_Tracking.ProjectManagementClasses"
        Title="ChangeOrderQuoteWindow" Height="1000" Width="1410" Closing="Window_Closing" Loaded="Window_Loaded"
        SizeToContent="WidthAndHeight"
        >

    <Window.Resources>
        <staticData:StatusToColorCo x:Key="StatusToColorCo" />
        <staticData:BackgroundColorCell x:Key="BackgroundColorCell" />
        <staticData:SumSellGroupConverter x:Key="SumSellCostCodeTotal"/>
        <staticData:SumCostGroupConverter x:Key="SumCostCostCodeTotal"/>
        <staticData:SumGroupCostCodeName x:Key="SumCostCodeName"/>
        <staticDataTwo:CostCodeDropDowns x:Key="CostCodeDropDowns" />
        <staticDataTwo:SubmittalItemType x:Key="SubmittalItemType" />
        <staticDataTwo:LabourValueContainer x:Key="LabourValueContainer" />
        <staticData:IsLabourToColour x:Key="IsLabourToColour" />
        <staticDataTwo:UserCompleteList x:Key="UserCompleteList" />

        <ObjectDataProvider x:Key="dataFromEnum" MethodName="GetValues"
                            ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="staticDataTwo:ChangeLabourType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <Style x:Key="GroupHeaderStyle" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <Expander x:Name="exp" IsExpanded="False" Background="White" Foreground="Black">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Name="TotalSize" Text="Total size here"  Margin="290 0 0 0" />
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter Margin="20 0 0 0" />
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MaleFemaleStyle" TargetType="DataGridCell">
            <!--<Setter Property="Background" Value="{Binding Path=., Converter={StaticResource BackgroundColorCell}}" />-->
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{Binding Path=., Converter={StaticResource BackgroundColorCell}}"
					        SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" TextBlock.FontSize="9" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">

    <Grid Background="#FF494949">
        <!--<Grid.RowDefinitions>
            <RowDefinition Height="400" />
            <RowDefinition />
        </Grid.RowDefinitions>-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" >
            <StackPanel Name="StckPan_Header" Orientation="Vertical">

                <StackPanel Name="StckPan_HeaderInfo" Margin="5,10,0,0" Orientation="Vertical">
                    <Label Name="LBL_QuoteNumber" Content="{Binding QuoteNumber}" Margin="0,2,0,0" Height="20" FontSize="16" FontWeight="Bold" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                    <!--<Label Content="PROJECT NO." Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Margin="0,2,0,0" Height="20"  Width="220" FontSize="9" HorizontalAlignment="Left"/>-->
                    <Label Content="CONTRACTOR" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Text="{Binding Contractor}" Margin="0,2,0,0" Height="20"  Width="220" FontSize="10"  HorizontalAlignment="Left" VerticalContentAlignment="Center" IsReadOnly="True"/>
                    <Label Content="CONTRACT NO." Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Text="{Binding ContractNumber, NotifyOnTargetUpdated=True, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="0,2,0,0" Height="20"  Width="220" FontSize="10"  HorizontalAlignment="Left" VerticalContentAlignment="Center" />
                    <Label Content="CHANGE ID" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Text="{Binding ContractorChangeId, NotifyOnTargetUpdated=True, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="0,2,0,0" Height="20"  Width="220" FontSize="10"  HorizontalAlignment="Left" VerticalContentAlignment="Center" />
                    
                    <!--<Label Content="PROJECT NAME" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Margin="0,2,0,0" Height="20"  Width="220" FontSize="9"  HorizontalAlignment="Left" IsReadOnly="True" />-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="DATE CREATED" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Text="{Binding DateCreated, StringFormat=\{0:dd \MMM \yyyy\}}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" IsReadOnly="True"/> 
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="OVERHEAD" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_OverheadPercentage" Text="{Binding OverheadPercentage, NotifyOnTargetUpdated=True, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="PROFIT" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_ProfitPercentage" Text="{Binding ProfitPercentage, NotifyOnTargetUpdated=True, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="SUBTOTAL" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_SubTotal" Text="{Binding SubtotalUI, StringFormat=N2, UpdateSourceTrigger=LostFocus}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="OVERHEAD AMT." Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_OverheadAmount" Text="{Binding OverheadAmountUI, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" IsReadOnly="True"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="PROFIT AMT." Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_ProfitAmount" Text="{Binding ProfitAmountUI, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" IsReadOnly="True"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="TOTAL COST" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_TotalCost" Text="{Binding TotalCostUI, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" IsReadOnly="True"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" >
                        <Label Content="MARGIN" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_Margin" Text="{Binding MarginUi, StringFormat=N2, NotifyOnTargetUpdated=True, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,35,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" />
                    </StackPanel>
                        <StackPanel Orientation="Horizontal">
                        <Label Content="TOTAL" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                            <TextBox Name="TB_Total" Text="{Binding TotalUI, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Label Content="CHANGE REFERENCE" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Name="TB_ChangeReference" Text="{Binding ChangeReference}" Margin="0,2,35,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" />
                    </StackPanel>
                    <!--<Label Content="REVISED" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Margin="0,2,0,0" Height="20"  Width="220" FontSize="9"  HorizontalAlignment="Left" IsReadOnly="True"/>-->
                    <!--<Label Content="CHANGE ORDER NO." Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Text="{Binding QuoteNumber}" Margin="0,2,0,0" Height="20"  Width="220" FontSize="9"  HorizontalAlignment="Left" IsReadOnly="True"/>-->
                    <StackPanel Height="50" Width="220" Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Left" >
                        <StackPanel Width="110" Orientation="Vertical" HorizontalAlignment="Left">
                            <Label Content="TENT. APPROV."  Foreground="White" HorizontalContentAlignment="Center"/>
                            <CheckBox Name="ChkBox_TentativeApproval" IsChecked="{Binding TentativeApproval, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" Checked="ChkBox_TentativeApproval_Checked" Unchecked="ChkBox_TentativeApproval_Unchecked" />
                        </StackPanel>
                        <StackPanel Width="110" Orientation="Vertical">
                            <Label Content="APPROVED"  Foreground="White" HorizontalContentAlignment="Center"/>
                            <CheckBox Name="ChkBox_Approval" HorizontalAlignment="Center" Checked="ChkBox_Approval_Checked" Unchecked="ChkBox_Approval_Unchecked" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Width="110" Orientation="Vertical">
                            <Label Content="TENT. APPROV. DATE" Margin="0,2,0,0" Height="20" Width="110" FontSize="9" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                            <TextBox Name="TB_TentativeApprovalDate" Text="{Binding TentativeApprovalDate, StringFormat=\{0:dd \MMM \yyyy\}}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10"  HorizontalAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"/>
                        </StackPanel>
                        <StackPanel Width="110" Orientation="Vertical">
                            <Label Content="APPROVED DATE" Margin="0,2,0,0" Height="20" Width="110" FontSize="9" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                            <TextBox Name="TB_ApprovalDate" Text="{Binding ApprovalDate, StringFormat=\{0:dd \MMM \yyyy\}}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10"  HorizontalAlignment="Right" HorizontalContentAlignment="Center" IsReadOnly="True"/>                             
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="APPROVAL NUM." Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                        <TextBox Text="{Binding AuthorizationNumber}" Margin="0,2,0,0" Height="20"  Width="100" FontSize="10" HorizontalContentAlignment="Center" HorizontalAlignment="Center" IsReadOnly="True"/>
                    </StackPanel>
                    <!--<StackPanel Orientation="Horizontal" Visibility="Hidden">
                        <Label Content="PRICING BY" Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                        <ComboBox                       Name="Cbox_PricingBy"
                                                        Margin="0,2,0,0" Height="20" Width="120" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" 
                                                        ItemsSource="{Binding Source={StaticResource UserCompleteList}}"
                                                        SelectedItem="{Binding Path=User}" 
                                                        SelectedValuePath="DomainUserName"
                                                        SelectedValue="{Binding PrimeLead, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="DomainUserName" 
                                                        SelectionChanged="Cbox_PricingBy_SelectionChanged" 
                                                        >
                        </ComboBox>
                    </StackPanel>-->
                    <Label Content="DESCRIPTION" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Left" Padding="0,2,2,0" Foreground="White" />
                    <TextBox Text="{Binding HeaderDescription, NotifyOnTargetUpdated=True, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="0,2,0,0" Height="80"  Width="220" FontSize="10"  HorizontalAlignment="Left" AcceptsReturn="True" TextWrapping="Wrap" />            
                </StackPanel>
                <StackPanel Name="StckPan_AddChangeLine">
                    <Rectangle Margin="0,12,0,0" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                    <StackPanel Margin="5,10,0,0" Orientation="Vertical">
                        <Label Content="COST CODE" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                        <StackPanel Orientation="Vertical">
                            <ComboBox Name="CBox_CostCode" Margin="0,2,0,10" Width="220" HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                        ItemsSource="{Binding Source={StaticResource CostCodeDropDowns}}"
                                        SelectedItem="{Binding Path=CostCodeType}" 
                                        SelectedValue="{Binding Path=CostCodeType.CostCode}"
                                        SelectedValuePath="CostCode" 
                                        SelectionChanged="CBox_CostCode_SelectionChanged"
                                        >
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding CostCode}" />
                                            <Run Text="{Binding Description}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Label Name="LBL_CostCodeDescription" Margin="10,-8,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                        </StackPanel>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Label Content="LABOUR"  Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                                <CheckBox Name="ChkBx_Labour" IsChecked="{Binding IsLabour}"  Margin="4,4,0,0" HorizontalAlignment="Center" Checked="ChkBx_Labour_Checked" Unchecked="ChkBx_Labour_Unchecked" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <ComboBox Name="CBox_LabourType" Margin="0,2,0,10" Width="220" HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                        ItemsSource="{Binding Source={StaticResource LabourValueContainer}}"
                                        SelectedItem="{Binding Path=LabourValuePair}" 
                                        SelectedValue="{Binding Path=LabourValuePair.Value}"
                                        SelectedValuePath="Key" 
                                        SelectionChanged="CBox_LabourType_SelectionChanged"
                                        >
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                            <Run Text="{Binding Key}" />
                                             <Run Text=" - " />
                                            <Run Text="{Binding Value}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Label Name="LBL_LabourCodeDescription" Margin="10,2,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Name="BTN_AddChangeLine" Margin="0,2,10,0" Content="ADD" Height="20" Width="100" Click="BTN_AddChangeLine_Click"   />
                            <Button Name="BTN_ClearFields" Margin="0,2,10,0" Content="CLEAR" Height="20" Width="100" Click="BTN_ClearFields_Click"   />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <!--<Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />-->
                    <!--<Button Name="BTN_CreateRevision" Content="REVISION" Margin="0,0,0,0" Height="20" Width="100" HorizontalAlignment="Center" />
                    <Button Name="BTN_CancelQuote" Content="CANCEL" Margin="0,10,0,0" Height="20" Width="100" HorizontalAlignment="Center" />-->
                    <Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                    <Button Name="BTN_AddHwFromSchedule" Content="ADD HARDWARE FROM SCHEDULE" Margin="0,0,0,0" Height="20" Width="200" HorizontalAlignment="Center" Click="BTN_AddHwFromSchedule_Click"  />
                    <Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                    <Button Name="BTN_UpdateServer" Content="UPDATE / SAVE CHANGES" Margin="0,0,0,0" Height="20" Width="160" HorizontalAlignment="Center" Click="BTN_UpdateServer_Click"/>
                    <Rectangle Margin="0,12,0,12" Width="80" HorizontalAlignment="Center" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                    <TextBlock TextWrapping="WrapWithOverflow" Width="200" Height="40" Foreground="White" IsEnabled="False">
                        - Please remember to include freight
                        - Standard rates
                        - List less 20
                    </TextBlock>
                    <Button Name="BTN_GenerateWordExport" Content="EXPORT TO WORD" Style="{StaticResource WordExportButton}" Margin="0,0,0,0" Height="20" Width="120" HorizontalAlignment="Center" Click="BTN_GenerateWordExport_Click" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Label Content="ITEMIZED EXPORT" Margin="0,2,0,0" Height="20" HorizontalContentAlignment="Center" Padding="0,2,2,0" Foreground="White" />
                        <CheckBox Name="CBox_ItemizedWordExport"  Margin="4,4,0,0" HorizontalAlignment="Center" />
                        
                    </StackPanel>
                </StackPanel>                    
            </StackPanel>
        </Grid>
        
        <Grid  Grid.Column="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="260" />
                <RowDefinition Height="200" />
                <RowDefinition Height="*" />
             </Grid.RowDefinitions>

             <StackPanel Grid.Row="0" Orientation="Vertical">
                <Label Content="COST CODE TOTALS (Including Labour)" Foreground="White" />
                    <ScrollViewer  Height="240">
                        <Grid>
                            <DataGrid Name="DG_ChangeOrderSums"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    RowHeaderWidth="0"
                                    ColumnHeaderHeight="45"
                                    VirtualizingStackPanel.IsVirtualizing="True" 
                                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                                    RowHeight="0"
                              >
                                <DataGrid.RowStyle>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="{x:Type GroupItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                                            <DockPanel>
                                                                <Grid DockPanel.Dock="Bottom" Background="#FF494949">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition />
                                                                        <RowDefinition />
                                                                    </Grid.RowDefinitions>

                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Grid.Column="0" 
                                                                       Foreground="White"
                                                                       Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumCostCodeName}}" 
                                                                       FontWeight="Bold"/>
                                                                    </StackPanel>
                                                                    <!--<Line Grid.Column="1" Stroke="Black" X2="500" Fill="Black" VerticalAlignment="Center" />-->
                                                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="100,0,0,0"  Orientation="Horizontal">
                                                                        <TextBlock Grid.Row="1"  HorizontalAlignment="Left" Margin="0,0,0,10" Width="240" Foreground="White"
                                                                       Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumCostCostCodeTotal}}" />
                                                                        <TextBlock Grid.Row="1"  Margin="20,0,0,0" Width="240" Foreground="White"
                                                                       Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumSellCostCodeTotal}}" />
                                                                    </StackPanel>

                                                                </Grid>
                                                                <ItemsPresenter />
                                                            </DockPanel>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>

                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Vertical">
                    <Label Content="LABOUR TOTALS" Foreground="White"/>
                    <ScrollViewer  Height="180">
                        <Grid>
                            <DataGrid Name="DG_LabourSums"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    RowHeaderWidth="0"
                                    ColumnHeaderHeight="45"
                                    VirtualizingStackPanel.IsVirtualizing="True" 
                                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                                    RowHeight="0"
                              >
                                <DataGrid.RowStyle>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="{x:Type GroupItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                                            <DockPanel>
                                                                <Grid DockPanel.Dock="Bottom" Background="#FF494949">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition />
                                                                        <RowDefinition />
                                                                    </Grid.RowDefinitions>

                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Grid.Column="0" 
                                                                       Foreground="White"
                                                                       Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumCostCodeName}}" 
                                                                       FontWeight="Bold"/>
                                                                    </StackPanel>
                                                                    <!--<Line Grid.Column="1" Stroke="Black" X2="500" Fill="Black" VerticalAlignment="Center" />-->
                                                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="100,0,0,0"  Orientation="Horizontal">
                                                                        <TextBlock Grid.Row="1"  HorizontalAlignment="Left" Margin="0,0,0,10" Width="240" Foreground="White"
                                                                       Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumCostCostCodeTotal}}" />
                                                                        <TextBlock Grid.Row="1"  Margin="20,0,0,0" Width="240" Foreground="White"
                                                                       Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumSellCostCodeTotal}}" />
                                                                    </StackPanel>

                                                                </Grid>
                                                                <ItemsPresenter />
                                                            </DockPanel>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>

                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </ScrollViewer>
                </StackPanel>

                <DataGrid    
                    Grid.Row="2"
                    Name="DG_ChangeOrderLines"                              
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    ColumnHeaderHeight="45"
                    VirtualizingStackPanel.IsVirtualizing="True" 
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    SelectionMode="Single" AddingNewItem="DG_ChangeOrderLines_AddingNewItem" SourceUpdated="DG_ChangeOrderLines_SourceUpdated"
                    
                    MaxHeight="800"
                    >
                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="{x:Type GroupItem}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                                <DockPanel>
                                                    <Grid DockPanel.Dock="Top">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <StackPanel Orientation="Horizontal">

                                                            <TextBlock Grid.Column="0" 
                                                                    Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumCostCodeName}}" 
                                                                    FontWeight="Bold"/>
                                                        </StackPanel>
                                                        <Line Grid.Column="1" Stroke="Black" X2="500" Fill="Black" VerticalAlignment="Center" />

                                                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,0,5"
                                                                Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupItem}}, Converter={StaticResource ResourceKey=SumSellCostCodeTotal}}" />
                                                    </Grid>
                                                    <ItemsPresenter />
                                                </DockPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </DataGrid.GroupStyle>
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn x:Name="DG_ChangeOrderLines_Delete" Header="DEL" Width="25" Binding="{Binding Path=IsDeleted, Mode=TwoWay}">

                        </DataGridCheckBoxColumn>
                        <DataGridTemplateColumn Header="MOD" Width="25" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Rectangle Fill="{Binding IsModified, Converter={StaticResource StatusToColorCo}}" Width="16" Height="16" Margin="0,2,5,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_CostCode" Header="COST CODE" Width="90" Binding="{Binding CostCode}" IsReadOnly="True">

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_CostCodeNumber" Header="COST CODE NUM." Width="40" Binding="{Binding CostCodeSerial}" IsReadOnly="True">

                        </DataGridTextColumn>
                        <DataGridTemplateColumn x:Name="DG_ChangeOrderLines_SourceHardwareSched" Header="SRC. HW SCHED." Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X"
                                                                Click="OpenHardwareItemWindow"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn x:Name="DG_ChangeOrderLines_IsLabour" Header="IS LABOUR" Width="40" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Rectangle Fill="{Binding IsLabour, Converter={StaticResource IsLabourToColour}}" Width="16" Height="16" Margin="0,2,5,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_Description" Header="DESCRIPTION" Width="300" FontSize="11" Binding="{Binding LineDescription,NotifyOnTargetUpdated=True, UpdateSourceTrigger=LostFocus, Mode=TwoWay}">
                            <DataGridTextColumn.ElementStyle>
                                <Style>
                                    <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                    <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridCheckBoxColumn x:Name="DG_ChangeOrderLines_Billed" Header="BILLED" Width="50" Binding="{Binding Path=Billed, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False">

                            <DataGridCheckBoxColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Billed}" Value="False">
                                            <!--<Setter Property="Background" Value="Gray"/>
                                                        <Setter Property="BorderBrush" Value="Gray"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                                                        <Setter Property="Template" >
                                                            <Setter.Value>
                                                                
                                                            </Setter.Value>
                                                        </Setter>-->
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                        <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                                        SnapsToDevicePixels="True">
                                                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" TextBlock.FontSize="9" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Completed}" Value="True">
                                            <Setter Property="Background" Value="LightGreen"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridCheckBoxColumn.CellStyle>

                        </DataGridCheckBoxColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_Quantity" Header="QTY" Width="60" Binding="{Binding Quantity, NotifyOnTargetUpdated=True, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" >

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_QuantityBilled" Header="QTY BILLED" Width="40" Binding="{Binding QuantityDrawnPrevious}" CellStyle="{StaticResource MaleFemaleStyle}" IsReadOnly="True">

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_ListPrice" Header="LIST PRICE)" Width="80" Binding="{Binding SellPrice, NotifyOnTargetUpdated=True, UpdateSourceTrigger=LostFocus, Mode=TwoWay, StringFormat=N2}" >

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_Discount" Header="DISCOUNT (Typ. 20%)" Width="100" Binding="{Binding Discount, NotifyOnTargetUpdated=True, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" >

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_ListMinusTwenty" Header="LIST PRICE MINUS 20 (SELL (per item))" Width="80" Binding="{Binding SellPriceMinusDiscount, NotifyOnTargetUpdated=True, UpdateSourceTrigger=LostFocus, Mode=TwoWay, StringFormat=N2}" >

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_ExtendedPrice" Header="QUOTED SELL (extended)" Width="80" Binding="{Binding ExtendedSellPrice, NotifyOnTargetUpdated=True, StringFormat=N2}" IsReadOnly="True">

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_LineCost"  Header="LINE COST (FORM. UCSH ITEM COST)" Width="100" Binding="{Binding CostUcsh, NotifyOnTargetUpdated=True, UpdateSourceTrigger=LostFocus, Mode=TwoWay, StringFormat=N2}" >

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_Multiplier"  Header="MULTIPLIER" Width="100" Binding="{Binding Multiplier, NotifyOnTargetUpdated=True, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" >

                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_ExtendedCost"  Header="EXTENDED LINE COST (FORM. TOTAL LINE COST)" Width="100" Binding="{Binding TotalLineCostUcsh, NotifyOnTargetUpdated=True, StringFormat=N2}" IsReadOnly="True">

                        </DataGridTextColumn>
                        <!--<DataGridTemplateColumn Header="DELETE" Width="60">
                            <DataGridTemplateColumn.CellTemplate> 
                                <DataTemplate>
                                    <Button Name="BTN_DeleteChangeLine" Content="X" Click="BTN_DeleteChangeLine_Click"
                                            Tag="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>-->
                        <DataGridTextColumn x:Name="DG_ChangeOrderLines_Remarks"  Header="REMARKS" Width="220" Binding="{Binding Remarks}" >

                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Grid>

    </ScrollViewer>
</Window>
