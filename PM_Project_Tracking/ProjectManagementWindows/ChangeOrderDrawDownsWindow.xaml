<Window x:Class="PM_Project_Tracking.ProjectManagementWindows.ChangeOrderDrawDownsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:staticData="clr-namespace:PM_Project_Tracking.ProjectManagementWindows"
        Title="ChangeOrderDrawDownsWindow" Height="600" Width="1000">
    <Window.Resources>
        <staticData:StatusToColor x:Key="StatusToColor" />
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border Name="Border" Background="{StaticResource BackgroundBrush}">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2,12,2" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#FF494949">
        <TabControl Background="#FF494949">
            <TabItem Header="AGGREGATE"  Background="#FF494949" Foreground="White">
                <Grid Grid.Row="0" Background="#FF494949" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="130" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Vertical"  Background="#FF494949">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="QUOTE NUMBER" Margin="10,10,0,0" Foreground="White" />
                            <TextBox Name="TB_QuoteNumberSearch" Margin="10,10,0,0" Width="120" HorizontalAlignment="Left" />
                            <Label Content="*Only quote lines from approved change orders will be displayed" Margin="40,0,0,0" VerticalContentAlignment="Center" Foreground="White"/>
                        </StackPanel>
                        <StackPanel>
                            <Rectangle Margin="20,10,20,0" Height="1" Opacity="0.3" Stroke="White" />
                        </StackPanel>
                        <StackPanel Name="StckPan_SelectedPbLine" Orientation="Horizontal">
                            <StackPanel Orientation="Vertical" Margin="10,10,0,0" Width="100">
                                <Label Content="JOB NUMBER" Foreground="White" />
                                <Label Content="{Binding JobNumber}" Margin="10,0,0,0" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="10,10,0,0" Width="250">
                                <Label Content="DESCRIPTION" Foreground="White" />
                                <TextBox Margin="10,4,0,0" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="10,10,0,0" Width="100">
                                <Label Content="BASE CONTRACT" Foreground="White" />
                                <Label Content="{Binding BaseContract}" Margin="10,4,0,0" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="10,10,0,0" Width="100">
                                <Label Content="COMPLETED" Foreground="White" />
                                <Label Content="{Binding CompletedAmount}" Margin="10,4,0,0" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="10,10,0,0" Width="100">
                                <Label Content="CURRENT" Foreground="White" />
                                <Label Content="{Binding CurrentAmount}" Margin="10,4,0,0" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="10,10,0,0" Width="100">
                                <Label Content="PREVIOUS" Foreground="White" />
                                <Label Content="{Binding PreviousAmount}" Margin="10,4,0,0" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <DataGrid Grid.Row="1" Name="DG_ChangeLineList"

                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        RowHeaderWidth="0"
                        ColumnHeaderHeight="45"
                        VirtualizingStackPanel.IsVirtualizing="True" 
                        VirtualizingStackPanel.VirtualizationMode="Recycling"
                        SelectionMode="Single"  >
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type DataGridCell}" >
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                            SnapsToDevicePixels="True">
                                                <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridCell_PreviewMouseLeftButtonDownShipRec"></EventSetter>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="JOB NUMBER" Binding="{Binding JobNumber}" Width="100" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="QUOTE NUMBER" Binding="{Binding QuoteNumber}" Width="80" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="COST CODE" Binding="{Binding CostCode}" Width="80" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="COST CODE LINE" Binding="{Binding CostCodeSerial}" Width="40" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding LineDescription}" Width="*" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="ORIGINAL QUANTITY" Binding="{Binding Quantity}" Width="60" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="SELL (per item)" Width="80" Binding="{Binding SellPrice, StringFormat=N2}" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="VALUE COMMITTED" Width="80" Binding="{Binding ExtendedSellPrice,  StringFormat=N2}" IsReadOnly="True">

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="QUANTITY DRAWN TO DATE" Binding="{Binding QuantityDrawnPrevious}" Width="60" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="QUANTITY TO DRAW" Binding="{Binding QuantitySelectedFromDataGrid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60" >

                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="COMMIT QUANTITY" Width="60" HeaderStyle="{StaticResource SelectableColumn}" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="COMPOSITION" Foreground="White">
                <Grid>
                    <DataGrid Grid.Row="1" Name="DG_DrawDowns"

                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    ColumnHeaderHeight="45"
                    VirtualizingStackPanel.IsVirtualizing="True" 
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    SelectionMode="Single"   >
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type DataGridCell}" >
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                        SnapsToDevicePixels="True">
                                                <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <!--<EventSetter Event="PreviewMouseLeftButtonDown" Handler="DG_DrawDowns_PreviewMouseLeftButtonDownShipRec"></EventSetter>-->
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="DEL" Width="25" Binding="{Binding Path=IsDeleted, Mode=TwoWay}">

                            </DataGridCheckBoxColumn>
                            <DataGridTemplateColumn Header="MOD" Width="25" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Rectangle Fill="{Binding IsModified, Converter={StaticResource StatusToColor}}" Width="16" Height="16" Margin="0,2,5,2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="QUOTE NUMBER" Binding="{Binding QuoteNumber}" Width="80" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="COST CODE" Binding="{Binding CostCode}" Width="80" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="COST CODE LINE" Binding="{Binding CostCodeSerial}" Width="40" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding LineDescription}" Width="*" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="ORIGINAL QUANTITY" Binding="{Binding OriginalQuantity}" Width="60" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="QUANTITY DRAWN" Binding="{Binding QuantityDrawn}" Width="60" IsReadOnly="True" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="SELL (per item)" Width="80" Binding="{Binding SellPrice, NotifyOnTargetUpdated=True, StringFormat=N2}" >

                            </DataGridTextColumn>
                            <DataGridTextColumn Header="VALUE COMMITTED" Width="80" Binding="{Binding AmountCommitted, NotifyOnTargetUpdated=True, StringFormat=N2}" IsReadOnly="True">

                            </DataGridTextColumn>
                            <!--<DataGridTemplateColumn Header="DELETE QUANTITY" Width="60" HeaderStyle="{StaticResource SelectableColumn}" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>-->
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
