                                        <TextBox Name="TB_TaskScheduler_TaskFilter" TextChanged="TB_TaskScheduler_TaskFilter_TextChanged" />
                                        <Label Content="AREA" Foreground="White"/>
                                        <TextBox Name="TB_TaskScheduler_AreaFilter" TextChanged="TB_TaskScheduler_AreaFilter_TextChanged" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
