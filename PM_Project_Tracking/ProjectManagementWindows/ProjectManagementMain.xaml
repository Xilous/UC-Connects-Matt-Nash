                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource UserTwoObjects}}" 
                                                        SelectedValue="{Binding AssignedToUser.DomainUserName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                                                        DisplayMemberPath="DomainUserName"
                                                        Text="{Binding AssignedToUser.DomainUserName, Mode=TwoWay}" FontSize="10" 
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>-->




