<Window x:Class="PM_Project_Tracking.ProjectManagementWindows.ChangeOrderHardwareItemSelect"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChangeOrderHardwareItemSelect" Height="800" Width="600">
    <Grid Background="#FF494949">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Vertical">
                <Label Content="Hardware Search" Margin="20,0,0,0" Foreground="White" />
                <TextBox Name="TB_SearchItemDescription" Margin="20,2,0,0" Width="200" HorizontalAlignment="Left" TextChanged="TB_SearchItemDescription_TextChanged" />
               
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <DataGrid Name="DG_HardwareItemList" 
                    FrozenColumnCount="1"                                  
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    ColumnHeaderHeight="45"
                    VirtualizingStackPanel.IsVirtualizing="True" 
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    SelectionMode="Single" MouseDoubleClick="DG_HardwareItemList_MouseDoubleClick"  >
                <DataGrid.Resources>
                    <Style TargetType="{x:Type DataGridCell}" >
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                            SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <!--<EventSetter Event="PreviewMouseLeftButtonDown" Handler="DG_HeaderCommentList_PreviewMouseLeftButtonDown"></EventSetter>-->
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PRODUCT LINE" Width="*" Binding="{Binding ProductHash}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MANUFACTURER LIST" Width="80" Binding="{Binding PriceBasis}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DISCOUNT" Width="80" Binding="{Binding Discount}" IsReadOnly="True">

                    </DataGridTextColumn>
                    <!--<DataGridTextColumn Header="COMMENT" Width="*" Binding="{Binding CommentText}" >

                    </DataGridTextColumn>-->
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
