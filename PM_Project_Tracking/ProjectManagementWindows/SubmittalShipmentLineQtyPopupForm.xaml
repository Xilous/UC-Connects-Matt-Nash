<Window x:Class="PM_Project_Tracking.ProjectManagementWindows.SubmittalShipmentLineQtyPopupForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PM_Project_Tracking.ProjectManagementWindows"
        xmlns:staticData="clr-namespace:PM_Project_Tracking.ProjectManagementWindows"
        mc:Ignorable="d"
        Title="SubmittalShipmentLineQtyPopupForm" Height="640" Width="800" >
    <Window.Resources>
        <staticData:CanPressYes x:Key="CanPressYes" />
    </Window.Resources>
    <Grid Background="#FF494949" >
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
                <Label Content="How many items would you like to include in this shipment?" Foreground="White" />
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Height="80">
                    <TextBox  
                        Name="TB_LineQuantity"
                        DataContext="{Binding ElementName=___No_Name_}"
                        Text="{Binding Path=ShipLineCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        Margin="10,10,10,10" Width="60" Height="60" FontSize="22" TextAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        TextChanged="TextBox_TextChanged" />
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <!--<StackPanel Orientation="Horizontal">
                            <ComboBox Margin="10,10,10,10" Width="150">
                            
                            </ComboBox>
                        </StackPanel>-->
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Button  Name="BTN_Yes" Content="CONTINUE" Margin="10,10,10,10" Height="20" Width="100" Click="BTN_Yes_Click" />
                            <Button Name="BTN_No" Content="CANCEL" Margin="10,10,10,10" Height="20" Width="100" Click="BTN_No_Click" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Vertical">
                    <Label Content="Would you like to commit this sample shipment?" Foreground="White" />
                    <Button Name="BTN_YesShip" Content="CONTINUE" Margin="10,10,10,10" Height="20" Width="100" HorizontalAlignment="Left" Click="BTN_YesShip_Click" />
                    <Button Name="BTN_AddShipRow" Content="ADD ROW" Margin="10,10,10,10" Height="20" Width="100" HorizontalAlignment="Left" Click="BTN_AddShipRow_Click"  />
                </StackPanel>
                <StackPanel Orientation="Vertical">
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <DataGrid Grid.Row="1" Name="DG_ShipLineList"
                                                                                                      
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="True"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single"   
                      >
                <DataGrid.Resources>
                    <Style TargetType="{x:Type DataGridCell}" >
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridCell_PreviewMouseLeftButtonDown"></EventSetter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="DELETE">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X"
                            Command="Delete"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!--<DataGridTextColumn Header="PO NUMBER" Binding="{Binding PoNumber}" Width="80" IsReadOnly="True">

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SOP NUMBER" Binding="{Binding PoNumber}" Width="80" IsReadOnly="True">

                    </DataGridTextColumn>-->
                    <DataGridTextColumn Header="INDEX" Binding="{Binding Polnenum}" Width="80" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <!--<DataGridTextColumn Header="JOB NUMBER" Binding="{Binding JobNumber}" Width="90" IsReadOnly="True" >

                    </DataGridTextColumn>-->
                    <DataGridTextColumn Header="ITEM NUMBER" Binding="{Binding ItemNumber}" Width="120" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ITEM DESCRIPTION" Binding="{Binding ItemDescription, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="*" IsReadOnly="False" >

                    </DataGridTextColumn>
                    <!--<DataGridTextColumn Header="ORIG. ORDER QUANTITY" Binding="{Binding QuantityOrdered}" Width="80" IsReadOnly="True" >

                    </DataGridTextColumn>-->
                    <DataGridTextColumn Header="SHIP QUANTITY" Binding="{Binding QuantityShipped, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="80" IsReadOnly="False" >

                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
