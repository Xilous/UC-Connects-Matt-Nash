                        <Border Name="Border" BorderBrush="#2B5797" BorderThickness="2" Background="{StaticResource BackgroundBrush}" >
                            <!-- <ContentControl Name="ContentControl" TextBlock.FontSize="12" Foreground="Red" Background="Aqua" BorderBrush="BlueViolet" TextBlock.Foreground="White"/> -->
