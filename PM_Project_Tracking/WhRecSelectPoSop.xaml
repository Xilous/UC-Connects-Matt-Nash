<Window x:Class="PM_Project_Tracking.WhRecSelectPoSop"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhRecSelectPoSop" Height="600" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel Orientation="Vertical">
                <Label Content="SEARCH PO NUMBER" Margin="10,10,0,0" Foreground="White" />
                <TextBox Name="TB_PoSearch" Margin="10,10,0,0" Width="120" HorizontalAlignment="Left" TextChanged="TB_PoSearch_TextChanged"/>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_PoHeaderList"                                        
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single" MouseDoubleClick="DG_PoHeaderList_MouseDoubleClick" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="PO NUMBER" Binding="{Binding PoNumber}" Width="120" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="SOP NUMBER" Binding="{Binding SopNumber}" Width="*" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="BUYER ID" Binding="{Binding BuyerId}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
