<Window x:Class="PM_Project_Tracking.QsNewJobQuote"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PM_Project_Tracking"
        mc:Ignorable="d"
        Title="QsNewJobQuote" Height="600" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel Orientation="Vertical">
                <Label Content="SEARCH PROJECT NUMBER (Job list sourced from 'Bid Projects' list)" Margin="10,10,0,0" Foreground="White" />
                <TextBox Name="TB_JobNumberSearch" Margin="10,10,0,0" Width="120" HorizontalAlignment="Left" TextChanged="TB_JobNumberSearch_TextChanged"  />
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_JobList"
                                                                                                      
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single" MouseDoubleClick="DG_JobList_MouseDoubleClick"   >
            <DataGrid.Columns>
                <DataGridTextColumn Header="JOB NUMBER" Binding="{Binding Key, Mode=OneWay}" Width="80">

                </DataGridTextColumn>
                <DataGridTextColumn Header="JOB NAME" Binding="{Binding Value, Mode=OneWay}" Width="*">

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
