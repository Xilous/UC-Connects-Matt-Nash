<Window x:Class="PM_Project_Tracking.CreateNewProjectMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CreateNewProjectMenu" Height="200" Width="300">
    <Grid Background="#FF494949">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Label Margin="20,5,5,5" Content="JOB NUMBER" Width="100" Foreground="White"/>
                <TextBox Margin="0,5,0,5" Width="140" Style="{StaticResource PrimaryTextBox}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="20,5,5,5" Content="JOB NAME" Width="100" Foreground="White"/>
                <TextBox Margin="0,5,0,5" Width="140" Style="{StaticResource PrimaryTextBox}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="20,5,5,5" Content="CONSULTANT" Width="100" Foreground="White"/>
                <ComboBox Margin="0,5,0,5" Width="140" />
            </StackPanel>
            <Button Content="CREATE JOB" Margin="120,15,5,5" Height="20" Width="120" />


        </StackPanel>
    </Grid>
</Window>
