<Window x:Class="PM_Project_Tracking.WhRecSelectPoUnusual"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhRecSelectPoUnusual" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Vertical" Width="200" HorizontalAlignment="left">
                    <Label Content="SEARCH PO NUMBER" Margin="10,10,0,0" Foreground="White" />
                    <TextBox Name="TB_PoSearch" Margin="10,10,0,0" Width="120" HorizontalAlignment="Left" TextChanged="TB_PoSearch_TextChanged" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Width="120" HorizontalAlignment="left">
                        <Label Margin="10,10,0,0" Foreground="White" Width="120" >
                            <TextBlock>1 – New<LineBreak/>2 – Released<LineBreak/>3 – Change Order </TextBlock>
                        </Label>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Width="120" HorizontalAlignment="left">
                        <Label Margin="10,10,0,0" Foreground="White" Width="120" >
                            <TextBlock>4 – Received<LineBreak/>5 – Closed<LineBreak/>6 – Cancelled</TextBlock>
                        </Label>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Width="300" HorizontalAlignment="left">
                        <Label Margin="10,10,0,0" Foreground="White" Width="300" >
                            <TextBlock>The POs on the list have the following properties<LineBreak/>
                                - They are not retail orders<LineBreak/>
                                - They are not located in showroom<LineBreak/>
                                - They do not have job numbers
                            </TextBlock>
                        </Label>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_PoHeaderList"
                                                                                                      
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single" MouseDoubleClick="DG_PoHeaderList_MouseDoubleClick"  >
            <DataGrid.Columns>
                <DataGridTextColumn Header="PO NUMBER" Binding="{Binding PoNumber}" Width="100" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="PO STATUS" Binding="{Binding PoStatus}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="LOCATION CODE" Binding="{Binding LocationCode}" Width="*" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="BUYER ID" Binding="{Binding BuyerId}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
