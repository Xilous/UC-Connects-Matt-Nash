<Window x:Class="PM_Project_Tracking.TransferModifyUserMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:staticData="clr-namespace:PM_Project_Tracking"
        Title="TransferUserMenu" Height="360" Width="440">
    <Window.Resources>
        <staticData:PermissionTier x:Key="PermissionTier" />
        
        <SolidColorBrush x:Key="SolidBorderBrush" Color="#888" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FF494949" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#FF575555" />
        <SolidColorBrush x:Key="BillingGridBorderBrush" Color="#FF8DB258" />
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border Name="Border" Background="{StaticResource BackgroundBrush}">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2,12,2" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#FF494949">
        <TabControl TabStripPlacement="Top" Background="#FF494949" Foreground="White">
            <TabItem Header="MAIN ROLE" Background="#FF494949" Foreground="White">
                <Grid>
                    <StackPanel Name="StckPan_UserSP" Orientation="Vertical" Margin="0,10,0,0" >
                    <StackPanel Orientation="Horizontal">
                        <Label Margin="10,5,5,5" Content="NAME" Width="130" Foreground="White"/>
                        <TextBox Name="TB_DomainUserName" Margin="0,5,0,5" Width="140"  IsReadOnly="True"  />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Margin="10,5,5,5" Content="PERMISSIONS TIER" Width="130" Foreground="White"/>
                        <ComboBox Name="CBox_PermissionTier" Margin="0,5,0,5" Width="140" 
                                  ItemsSource="{Binding Source={StaticResource PermissionTier}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Margin="10,5,5,5" Content="EMAIL" Width="130" Foreground="White"/>
                        <TextBox Name="TB_UserEmail" Margin="0,5,0,5" Width="140"  />
                    </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Margin="10,5,5,5" Content="IS EMPLOYED" Width="130" Foreground="White"/>
                            <CheckBox Name="ChkBox_IsActive" IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Margin="7" VerticalContentAlignment="Top" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="40,0,0,0" HorizontalAlignment="Left" >
                            <Button Name="BTN_ModifyUser" Content="MODIFY USER"  Margin="105,15,5,5" Height="20" Width="140" Click="BTN_ModifyUser_Click" />
                            <Rectangle Margin="0,15,0,0" Height="2" Width="250" VerticalAlignment="Top" HorizontalAlignment="Center" Fill="LightGray" Opacity="0.3" />
                            <Button Name="BTN_DeleteUser" Content="DELETE USER" Margin="105,15,5,5" Height="20" Width="140" Click="BTN_DeleteUser_Click"  />
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="SECONDARY ROLES" Background="#FF494949" Foreground="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />

                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Vertical">
                            <Label Content="USER" Margin="10,5,5,5" Width="220" HorizontalAlignment="Left" Foreground="White"/>
                            <TextBox Name="TB_SecondaryRoles_ExistingUser" Margin="10,5,5,5" Width="200" HorizontalAlignment="Left"  IsReadOnly="True"  />
                            <!--<ComboBox Name="Cbox_Associations_SelectExistingUser" SelectedValue="{Binding DomainUserName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="DomainUserName"
                                                        Text="{Binding DomainUserName, Mode=TwoWay}" FontSize="11"  Margin="10,5,5,5" Width="200" HorizontalAlignment="Left"/>-->
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="SELECT SECONDARY ROLE" Margin="10,5,5,5" Width="260" HorizontalAlignment="Left" Foreground="White"/>
                            <ComboBox Name="Cbox_SecondaryRoles_SelectUserRole" 
                                      SelectedValue="{Binding RoleId, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="RoleName"
                                                        Text="{Binding RoleId, Mode=TwoWay}" FontSize="11"  Margin="10,5,5,5" Width="200" HorizontalAlignment="Left"  />
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Button Name="BTN_SecondaryRoles_SecondaryRole" Content="ADD SECONDARY ROLE" Margin="10,20,5,5" Height="20" Width="140" HorizontalAlignment="Left" Click="BTN_SecondaryRoles_SecondaryRole_Click"  />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="ASSOCIATIONS" Foreground="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />

                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Vertical">
                            <Label Content="USER" Margin="10,5,5,5" Width="220" HorizontalAlignment="Left" Foreground="White"/>
                            <TextBox Name="TB_Associations_ExistingUser" Margin="10,5,5,5" Width="200" HorizontalAlignment="Left"  IsReadOnly="True"  />
                            <!--<ComboBox Name="Cbox_Associations_SelectExistingUser" SelectedValue="{Binding DomainUserName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="DomainUserName"
                                                        Text="{Binding DomainUserName, Mode=TwoWay}" FontSize="11"  Margin="10,5,5,5" Width="200" HorizontalAlignment="Left"/>-->
                        </StackPanel>
                         <StackPanel Orientation="Vertical">
                            <Label Content="SELECT ASSOCIATION TYPE" Margin="10,5,5,5" Width="260" HorizontalAlignment="Left" Foreground="White"/>
                            <ComboBox Name="Cbox_Associations_SelectAssociationType" 
                                      SelectedValue="{Binding AssociationType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="AssociationValue"
                                                        Text="{Binding AssociationType, Mode=TwoWay}" FontSize="11"  Margin="10,5,5,5" Width="200" HorizontalAlignment="Left" SelectionChanged="Cbox_Associations_SelectAssociationType_SelectionChanged"/>
                        </StackPanel>                       
                        <StackPanel Orientation="Vertical">
                            <Label Content="SELECT USER IN GP TO ASSOCIATE WITH" Margin="10,5,5,5" Width="260" HorizontalAlignment="Left" Foreground="White"/>
                            <ComboBox Name="Cbox_Associations_SelectUserToAssociate"  SelectedValue="{Binding AssociationType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="AssociationValue"
                                                        Text="{Binding AssociationType, Mode=TwoWay}" FontSize="11"  Margin="10,5,5,5" Width="200" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Button Name="BTN_Associations_AddAssociation" Content="ADD ASSOCIATION" Margin="10,20,5,5" Height="20" Width="140" HorizontalAlignment="Left" Click="BTN_Associations_AddAssociation_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="OVERRIDES" Foreground="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />

                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Vertical">
                            <Label Content="USER" Margin="10,5,5,5" Width="150" HorizontalAlignment="Left" Foreground="White"/>
                            <TextBox Name="TB_Overrides_ExistingUser" Margin="10,5,5,5" Width="200" HorizontalAlignment="Left"  IsReadOnly="True"  />
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="SELECT OVERRIDE TYPE" Margin="10,5,5,5" Width="260" HorizontalAlignment="Left" Foreground="White"/>
                            <ComboBox Name="Cbox_Overrides_SelectOverrideType"  Margin="10,5,5,5" Width="200" HorizontalAlignment="Left" SelectionChanged="Cbox_Overrides_SelectOverrideType_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="SELECT OVERRIDE NAME" Margin="10,5,5,5" Width="260" HorizontalAlignment="Left" Foreground="White"/>
                            <ComboBox Name="Cbox_Overrides_SelectOverrideName" SelectedValue="{Binding OverrideName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="OverrideName"
                                                        Text="{Binding OverrideName, Mode=TwoWay}" FontSize="11"  Margin="10,5,5,5" Width="200" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Button Name="BTN_Overrides_AddOverride" Content="ADD OVERRIDE" Margin="10,20,5,5" Height="20" Width="140" HorizontalAlignment="Left" Click="BTN_Overrides_AddOverride_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
