<Window x:Class="PM_Project_Tracking.WhDeficiencyListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PM_Project_Tracking"
        mc:Ignorable="d"
        Title="WhDeficiencyListWindow" Height="800" Width="600" Closing="Window_Closing">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel Orientation="Vertical">
                <Button Name="BTN_CreateDeficienty" Content="ADD DEFICIENCY" Margin="0,40,0,0" Width="130" Height="20" HorizontalAlignment="Left" Click="BTN_CreateDeficienty_Click"  />
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_DeficiencyList"                                   
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single" >
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Completed}" Value="false">
                            <Setter Property="BorderBrush" Value="Red"></Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Completed}" Value="true">
                            <Setter Property="BorderBrush" Value="Green"></Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="COMPLETED" Width="40" Binding="{Binding Path=Completed, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsReadOnly="False">

                    <DataGridCheckBoxColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Completed, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Value="False">
                                    <!--<Setter Property="Background" Value="Gray"/>
                                                        <Setter Property="BorderBrush" Value="Gray"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                                                        <Setter Property="Template" >
                                                            <Setter.Value>
                                                                
                                                            </Setter.Value>
                                                        </Setter>-->
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" TextBlock.FontSize="9" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Completed}" Value="True">
                                    <Setter Property="Background" Value="LightGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridCheckBoxColumn.CellStyle>

                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="*" IsReadOnly="False">

                </DataGridTextColumn>
                <DataGridTextColumn Header="CREATED BY" Binding="{Binding UpdatingUser}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="DATE CREATED" Binding="{Binding DateCreated, StringFormat=\{0:dd \MMM \yyyy\}}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
