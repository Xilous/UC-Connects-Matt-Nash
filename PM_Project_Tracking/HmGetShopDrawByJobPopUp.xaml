<Window x:Class="PM_Project_Tracking.HmGetShopDrawByJobPopUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TransferProjectMenu" Height="600" Width="400">
    <Grid Background="#FF494949">
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel>
                <Label Content="Only projects that have been created in GP and are found in the &#10;'All Projects' menu will show up in the list below." Height="60" Foreground="White"/>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Width="100">
                        <Label Content="JOB NUMBER" Margin="0,0,0,0" Foreground="White" FontSize="8" HorizontalAlignment="Center" />
                        <TextBox Name="TB_JobNumberFilter" Width="80" FontSize="9" VerticalContentAlignment="Center" TextChanged="TB_JobNumberFilter_TextChanged"  />
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="100,0,0,0" >
                        <Label Content="JOB NAME" Foreground="White" FontSize="8" HorizontalAlignment="Center" />
                        <TextBox Name="TB_JobNameFilter" Width="80" FontSize="9" VerticalContentAlignment="Center" TextChanged="TB_JobNameFilter_TextChanged"  />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <DataGrid Name="DG_JobsList"
                AutoGenerateColumns="False"
                CanUserSortColumns="False"
                CanUserAddRows="False"
                RowHeaderWidth="0"
                ColumnHeaderHeight="45"
                VirtualizingStackPanel.IsVirtualizing="True" 
                VirtualizingStackPanel.VirtualizationMode="Recycling"
                CanUserDeleteRows="True"
                SelectionMode="Single" MouseDoubleClick="DG_JobsList_MouseDoubleClick" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="JOB NUMBER" Width="100" Binding="{Binding JobNumber}" IsReadOnly="True" >

                    </DataGridTextColumn>
                    <DataGridTextColumn Header="JOB NAME" Width="*" Binding="{Binding JobName}" IsReadOnly="True" >

                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
