<Window x:Class="PM_Project_Tracking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:staticData="clr-namespace:PM_Project_Tracking"
        xmlns:dataClassData="clr-namespace:PM_Project_Tracking.DataClasses"
        Title="MainWindow" Height="960" Width="1800" Loaded="Window_Loaded">

    <Window.Resources>
        <staticData:PursuitStatusActPend x:Key="PursuitStatusActPend" />
        <staticData:PursuitTenderPhase x:Key="PursuitTenderPhase" />
        <staticData:PursuitBranch x:Key="PursuitBranch" />
        <staticData:PursuitFacilityType x:Key="PursuitFacilityType" />
        <staticData:PursuitNewOrReno x:Key="PursuitNewOrReno" />
        <staticData:PursuitFundingType x:Key="PursuitFundingType" />
        <staticData:PursuitPriority x:Key="PursuitPriority" />
        <staticData:UserCompleteList x:Key="UserCompleteList" />
        <staticData:AvawareTeamList x:Key="AvawareTeamList" />
        <staticData:HardwareSchedWriterList x:Key="HardwareSchedWriterList" />

        <!--<staticData:QuoteSummaryJobQuoteList x:Key="QuoteSummaryJobQuoteList" />-->
        <staticData:QuoteSummaryInstDrop x:Key="QuoteSummaryInstDrop" />

        <staticData:CurrentDb x:Key="CurrentDb" />

        <!--<staticData:EnumToFriendlyNameConverter x:Key="enumItemsConverter"/>-->
        <ObjectDataProvider x:Key="QuoteSummaryEnum" MethodName="GetValues"
                        ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="dataClassData:QsInstaller"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <staticData:NoYesPendingList x:Key="NoYesPendingList" />
        <staticData:BidProjectStatusList x:Key="BidProjectStatusList" />
        <staticData:BidProjectDivisionList x:Key="BidProjectDivisionList" />
        <staticData:BidProjectTypeList x:Key="BidProjectTypeList" />
        <staticData:OfferToTenderStatusList x:Key="OfferToTenderStatusList" />
        <staticData:ContractStatusList x:Key="ContractStatusList" />
        <staticData:OneTwoThreeNa x:Key="OneTwoThreeNa" />
        <staticData:TrueFalse x:Key="TrueFalse" />
        <staticData:ProjectCoordinatorList x:Key="ProjectCoordinatorList" />
        <staticData:HardwareCoordinatorList x:Key="HardwareCoordinatorList" />

        <staticData:DateConverter x:Key="DateConverter" />
        <staticData:StatusToColor x:Key="StatusToColor" />
        <staticData:IndicatorColor x:Key="IndicatorColor" />
        <staticData:ChangeOrderConverter x:Key="ChangeOrderConverter" />
        <staticData:PercentageConverter x:Key="PercentageConverter" />
        <staticData:PopLinePolnestaStatusConverter  x:Key="PopLinePolnestaStatusConverter" />

        <staticData:SopLineStatus x:Key="SopLineStatus" />

        <SolidColorBrush x:Key="SolidBorderBrush" Color="#888" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FF494949" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#FF575555" />
        <SolidColorBrush x:Key="BillingGridBorderBrush" Color="#FF8DB258" />
        <!-- <SolidColorBrush x:Key="GreenBorderBrush2" Color="#FF8DB258" /> -->



        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border Name="Border" Background="{StaticResource BackgroundBrush}">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2,12,2" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Name="Container" Background="#FF494949">
        <Grid Name="MainNavigation" Margin="0, 40, 0, 0" Background="#FF494949">
            <TabControl TabStripPlacement="Left" Background="#FF494949" >
                <TabItem Header="PURSUITS" Name="Tab_Pursuits_Main" VerticalAlignment="Top" Width="185" Height="30" Background="#FF494949" Foreground="White" >
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="30" />
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Button Name="BTN_Pursuits_ExportToExcel" Content="EXPORT TO EXCEL" Margin="0,10,20,0" Width="100" Height="20" VerticalAlignment="top" HorizontalAlignment="Right" FontSize="8" Click="BTN_Pursuits_ExportToExcel_Click" />
                        <Grid Grid.Row="0" Width="400" HorizontalAlignment="Left">
                            <Rectangle Margin="5,5,0,0" Width="205" HorizontalAlignment="Left" Fill="{StaticResource SelectedBrush}" Opacity="0.3" Stroke="White" />
                            <StackPanel Orientation="Vertical">
                                <Button Name="BTN_Pursuits_UpdateServer" Content="UPDATE SERVER" Margin="20,10,0,0" Height="20" Width="170" HorizontalAlignment="left" Click="BTN_Pursuits_UpdateServer_Click"  />
                                <Rectangle Margin="20,5,0,0" Height="2" Width="170" VerticalAlignment="Top" HorizontalAlignment="Left" Fill="LightGray" Opacity="0.3" />
                                <StackPanel Margin="20,5,0,0"  Orientation="Horizontal" >
                                    <Label Content="IGNORE BID. / CONSULTING" Foreground="White"/>
                                    <CheckBox Name="ChkBox_Pursuits_IgnoreCompleted" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Rectangle Margin="20,5,0,0" Height="2" Width="170" VerticalAlignment="Top" HorizontalAlignment="Left" Fill="LightGray" Opacity="0.3" />
                                <Button Name="BTN_Pursuits_AddNewPursuit" Content="CREATE NEW PURSUIT" Margin="20,5,0,0" Height="20" Width="170" HorizontalAlignment="left" Click="BTN_Pursuits_AddNewPursuit_Click" />
                                <Rectangle Margin="20,5,0,0" Height="2" Width="170" VerticalAlignment="Top" HorizontalAlignment="Left" Fill="LightGray" Opacity="0.3" />
                                <Button Name="BTN_Pursuits_TransferPursuit" Content="TRANSFER PURSUITS TO BIDS" Margin="20,5,0,0" Height="20" Width="170" HorizontalAlignment="left" Click="BTN_Pursuits_TransferPursuit_Click"  />
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1">
                            <StackPanel Grid.Row="2" Orientation="Horizontal" >
                                <StackPanel Margin="0,0,0,0" Orientation="Horizontal"  VerticalAlignment="Center">
                                    <Label Content="JOB NAME FILTER" Margin="10,0,0,0" Foreground="White" FontSize="8" />
                                    <TextBox Name="TB_Pursuits_JobNameFilter" Width="240" FontSize="9" VerticalContentAlignment="Center" TextChanged="TB_Pursuits_JobNameFilter_TextChanged" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0" VerticalAlignment="Center">
                                    <Label Content="AND" Height="30" FontSize="9" Foreground="Wheat"  VerticalAlignment="Center" VerticalContentAlignment="Center" />
                                    <CheckBox Name="ChkBox_Pursuits_AndOr" Style="{DynamicResource CheckBoxSlider}" Height="30" Checked="ChkBox_Pursuits_AndOr_Checked"   />
                                    <Label Content="OR" Height="30" FontSize="9" Foreground="Wheat" VerticalAlignment="Center" VerticalContentAlignment="Center"  />
                                    <!--<CheckBox Name="ChkBox_And" Margin="7,-4,0,0" Checked="ChkBox_And_Checked" />-->
                                </StackPanel>
                                <StackPanel Margin="0,0,0,0" Orientation="Horizontal"  VerticalAlignment="Center">
                                    <Label Content="CONTRACTOR NAME FILTER" Margin="0,0,0,0" Foreground="White" FontSize="8" />
                                    <TextBox Name="TB_Pursuits_CustomerNameFilter" Width="230" FontSize="9" VerticalContentAlignment="Center" TextChanged="TB_Pursuits_CustomerNameFilter_TextChanged"  />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" >
                            <DataGrid         Name="DG_Pursuits_PursuitList"
                                FrozenColumnCount ="4"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                RowHeaderWidth="0"
                                ColumnHeaderHeight="45"
                                VirtualizingStackPanel.IsVirtualizing="True" 
                                VirtualizingStackPanel.VirtualizationMode="Recycling"
                                SelectionMode="Single" 
                                >
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="DEL" Width="25" Binding="{Binding Path=IsDeleted, Mode=TwoWay}">

                                    </DataGridCheckBoxColumn>
                                    <DataGridTemplateColumn Header="MOD" Width="25" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Rectangle Fill="{Binding IsModified, Converter={StaticResource StatusToColor}}" Width="16" Height="16" Margin="0,2,5,2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="ID" Width="40" Binding="{Binding Id}" IsReadOnly="False" >

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="JOB NUMBER" Width="80" Binding="{Binding JobNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="JOB NAME" Width="260" Binding="{Binding JobName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="TYPE" Width="80" Binding="{Binding PursuitType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>

                                    <!--<DataGridTextColumn Header="STATUS" Width="120" Binding="{Binding PursuitStatus, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True">

                                    </DataGridTextColumn>-->
                                    <DataGridTemplateColumn Header="STATUS" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource PursuitStatusActPend}}" 
                                                        SelectedValue="{Binding PursuitStatus, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding PursuitStatus, Mode=TwoWay}"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="PRIME LEAD" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource UserCompleteList}}"
                                                        SelectedItem="{Binding Path=User}" 
                                                        SelectedValuePath="DomainUserName"
                                                        SelectedValue="{Binding PrimeLead, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="DomainUserName" 
                                                        
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="HARDWARE SCHED. WRITER" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource HardwareSchedWriterList}}" 
                                                        SelectedItem="{Binding Path=UserRole}" 
                                                        SelectedValuePath="DomainUserName"
                                                        SelectedValue="{Binding HardwareSchedWriter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="DomainUserName" 
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="HARDWARE SCHED. ASSISTANT" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource HardwareCoordinatorList}}" 
                                                        SelectedValue="{Binding HardwareSchedAssistant, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding HardwareSchedAssistant, Mode=TwoWay}"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="ARCHITECT" Width="120" Binding="{Binding Architect, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="CONTRACTOR" Width="120" Binding="{Binding Contractor, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="CONTACT NAME" Width="120" Binding="{Binding ContactName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="CONTACT EMAIL" Width="120" Binding="{Binding ContactEmail, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="TENDER PHASE" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource PursuitTenderPhase}}" 
                                                        SelectedValue="{Binding TenderPhase, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding TenderPhase, Mode=TwoWay}" SelectionChanged="ComboBox_SelectionChanged"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="BRANCH" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource PursuitBranch}}" 
                                                        SelectedValue="{Binding Branch, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding Branch, Mode=TwoWay}"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="FACILITY TYPE" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource PursuitFacilityType}}" 
                                                        SelectedValue="{Binding FacilityType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding FacilityType, Mode=TwoWay}"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="NEW OR RENO" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource PursuitNewOrReno}}" 
                                                        SelectedValue="{Binding NewOrReno, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding NewOrReno, Mode=TwoWay}"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="DOOR COUNT (SIZE)" Width="80" Binding="{Binding DoorCount, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="COMPLEXITY LEVEL" Width="80" Binding="{Binding ComplexityLevel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="FUNDING TYPE" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource PursuitFundingType}}" 
                                                        SelectedValue="{Binding FundingType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding FundingType, Mode=TwoWay}"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="BID CLOSING DATE">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BidClosingDate, UpdateSourceTrigger=PropertyChanged, StringFormat=\{0:dd \MMM \yyyy\}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <DatePicker SelectedDate="{Binding BidClosingDate, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="BID CLOSING TIME">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BidClosingTime, UpdateSourceTrigger=PropertyChanged, StringFormat=\{0:HH:mm\}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <DatePicker SelectedDate="{Binding BidClosingTime, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="TIMELINE" Width="80" Binding="{Binding Timeline, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="JOB PRIORITY" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource PursuitPriority}}" 
                                                        SelectedValue="{Binding JobPriority, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Text="{Binding JobPriority, Mode=TwoWay}"
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="AVAWARE TEAM" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                        ItemsSource="{Binding Source={StaticResource AvawareTeamList}}"
                                                        SelectedItem="{Binding Path=User}" 
                                                        SelectedValuePath="DomainUserName"
                                                        SelectedValue="{Binding PrimeLead, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        DisplayMemberPath="DomainUserName" 
                                                        
                                                        >
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="KEYING SCHEDULE" Width="80" Binding="{Binding KeyingSchedule, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="CONSTRUCTION VALUE" Width="80" Binding="{Binding ConstructionValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ESTIMATED PROJECT VALUE" Width="80" Binding="{Binding EstimatedProjectValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="UNDER REVIEW COMPLETION PERCENTAGE" Width="80" Binding="{Binding UnderReviewCompletionPercentage, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="SUCCESS RATE" Width="80" Binding="{Binding SuccessRate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="SPECIFICATIONS" Width="80" Binding="{Binding Specifications, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">

                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </TabItem>


                <TabItem Header="QUOTE SUMMARY" Name="Tab_QuoteSummary_Main"  VerticalAlignment="Top" Width="185" Height="30" Background="#FF494949" Foreground="White">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto">
                        

                    
                    <Grid Name="Grid_QuoteSummary_Main">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="1100" />
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" >
                            <StackPanel Orientation="Vertical">
                                <Button Name="BTN_QuoteSummary_SelectJob" Margin="0,10,0,0" Content="SELECT JOB" Width="200" Click="BTN_QuoteSummary_SelectJob_Click" />
                                <Button Name="BTN_QuoteSummary_NewJob" Margin="0,10,0,0" Content="NEW JOB" Width="200" Click="BTN_QuoteSummary_NewJob_Click" />
                                <Button Name="BTN_QuoteSummary_ExportToWord" Margin="0,10,0,0" Content="EXPORT TO WORD" Style="{StaticResource WordExportButton}"  Height="20" Width="120" HorizontalAlignment="Center" Click="BTN_QuoteSummary_ExportToWord_Click" />
                                <Button Name="BTN_QuoteSummary_UpdateBid" Margin="0,10,0,0" Content="UPDATE BID" Height="20" Width="120" Click="BTN_QuoteSummary_UpdateBid_Click"  />
                                <Button Name="BTN_QuoteSummary_test" Content="test" Width="200" Click="BTN_QuoteSummary_test_Click" Visibility="Collapsed" />

                                <Label Content="QUOTE NUMBER" Foreground="white" />
                                <StackPanel Orientation="Horizontal">
                                    <!--<TextBox Name="TB_QuoteSummary_QuoteNumber" Width="110" />-->
                                    <ComboBox Name="CBox_QuoteSummary_SelectQuoteNumber" DataContext="null" Margin="5,0,0,0" Width="180"  HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                        
                                        SelectedValue="{Binding Path=QuoteSummary}"
                                        DisplayMemberPath="QuoteNumber"
                                        Text="QuoteNumber"
                                              
                                        SelectionChanged="CBox_QuoteSummary_SelectQuoteNumber_SelectionChanged" DataContextChanged="CBox_QuoteSummary_SelectQuoteNumber_DataContextChanged" 
                                        >
                                    </ComboBox>
                                </StackPanel>
                                <Button Name="BTN_QuoteSummary_NewQuote" Margin="9,5,5,5" Content="NEW QUOTE" Width="100" Height="20" HorizontalAlignment="Left" Click="BTN_QuoteSummary_NewQuote_Click" />
                                <!--<Label Content="REVISION NUMBER" Foreground="White" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Name="TB_QuoteSummary_RevisionNumber" Width="110" /> 
                                    <ComboBox Name="CBox_QuoteSummary_SelectRevisionNumber" Margin="5,0,0,0" Width="180" />
                                </StackPanel>-->
                                <Button Name="BTN_QuoteSummary_NewRevision" Margin="9,5,5,5" Content="NEW REVISION" Width="100" Height="20" HorizontalAlignment="Left" Click="BTN_QuoteSummary_NewRevision_Click" />
                                <Label Content="JOB NAME" Foreground="White" />
                                <TextBox Name="TB_QuoteSummary_JobName" Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="JOB NUMBER" Foreground="White"/>

                                </StackPanel>
                                <TextBox Name="TB_QuoteSummary_JobNumber"  Text="{Binding JobNumber, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                    <StackPanel Orientation="Horizontal" >
                                        <Label Content="PST" Foreground="White"/>
                                        <TextBox Name="LBL_QuoteSummary_PST" Width="40" Text="{Binding PstTax, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" />
                                    </StackPanel>
                                    <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                                        <Label Content="GST" Foreground="White"/>
                                        <TextBox Name="LBL_QuoteSummary_GST" Width="40" Text="{Binding GstTax, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" />
                                    </StackPanel>
                                </StackPanel>
                                <Label Content="CONTRACTOR" Foreground="white" />
                                <TextBox Name="TB_QuoteSummary_Contractor" Text="{Binding Contractor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Orientation="Vertical">
                                        <Label Content="# DOOR LEAFS" Foreground="white" />
                                        <TextBox Name="TB_QuoteSummary_NumberOfDoorLeafs" Text="{Binding NumberOfDoorLeafs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:#.##}}" />
                                    </StackPanel>
                                    <StackPanel Margin="10,0,0,0" Orientation="Vertical">
                                        <Label Content="REVENUE / LEAF" Foreground="white" />
                                        <Label Name="LBL_QuoteSummary_RevenuePerDoor"  Content="{Binding RevenuePerDoor, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" ContentStringFormat="{}{0:0.##}"
                                       HorizontalAlignment="Center"  Foreground="White" />
                                    </StackPanel>
                                </StackPanel>

                                <Label Content="CLOSING DATE" Foreground="white" />
                                <DatePicker Text="{Binding ClosingDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Name="LBL_QuoteSummary_FieldInstall" Content="FIELD INSTALL" Foreground="White" />
                                <ComboBox Name="Cbox_QuoteSummay_FieldInstall" 
                                                        ItemsSource="{Binding Source={StaticResource QuoteSummaryInstDrop}}" 
                                                        DisplayMemberPath="Value" 
                                                        SelectedValuePath="Key" 
                                                        SelectedValue="{Binding FieldInstall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        >
                                </ComboBox>
                                    <!--<ComboBox Name="Cbox_QuoteSummay_FieldInstall" 
                                          ItemsSource="{Binding Source={StaticResource QuoteSummaryEnum}}"
                                          SelectedItem="{Binding Path=FieldInstall, Mode=TwoWay}" Height="Auto">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Label  Content="{Binding   Path=.,Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource enumItemsConverter}}"
                                            Height="Auto"
                                            Margin="0" 
                                            VerticalAlignment="Center"
                                                    Foreground="White"
                                                    />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    
                                </ComboBox>-->
                                <!--<Label Name="LBL_QS_test1" Content="{Binding Path=FieldInstall}"  Foreground="White"  />-->
                                <Label Name="LBL_QuoteSummary_FrameInstall" Content="FRAME INSTALL" Foreground="White" />
                                <ComboBox Name="Cbox_QuoteSummay_FrameInstall" 
                                                        ItemsSource="{Binding Source={StaticResource QuoteSummaryInstDrop}}" 
                                                        DisplayMemberPath="Value" 
                                                        SelectedValuePath="Key" 
                                                        SelectedValue="{Binding FrameInstall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        >
                                </ComboBox>
                                <!--<Label Name="LBL_QS_test2" Content="{Binding Path=FrameInstall}"  Foreground="White"  />-->
                                <Label Name="LBL_QuoteSummary_AutoOperator" Content="AUTO OPERATOR" Foreground="White" />
                                <ComboBox Name="Cbox_QuoteSummay_AutoOperator" 
                                                        ItemsSource="{Binding Source={StaticResource QuoteSummaryInstDrop}}" 
                                                        DisplayMemberPath="Value" 
                                                        SelectedValuePath="Key" 
                                                        SelectedValue="{Binding AutoOperatorInstall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
