<Window x:Class="PM_Project_Tracking.WhShipGetRtlordLines"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhShippingRetRtlordLines" Height="600" Width="1600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF494949" >
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Vertical">
                    <Label Content="SEARCH PO NUMBER" Margin="10,10,0,0" Foreground="White" />
                    <TextBox Name="TB_PoNumberSearch" Margin="10,10,0,0" Width="120" HorizontalAlignment="Left" TextChanged="TB_PoNumberSearch_TextChanged"  />
                </StackPanel>
                <StackPanel>
                    <Label Content="SEARCH VENDOR" Margin="10,10,0,0" Foreground="White" />
                    <TextBox Name="TB_VendorNameSearch" Margin="10,10,0,0" Width="200" HorizontalAlignment="Left" TextChanged="TB_VendorNameSearch_TextChanged" />
                </StackPanel>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Name="DG_PoList"
                                                                                                      
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            RowHeaderWidth="0"
            ColumnHeaderHeight="45"
            VirtualizingStackPanel.IsVirtualizing="True" 
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            SelectionMode="Single"  >
            <DataGrid.Resources>
                <Style TargetType="{x:Type DataGridCell}" >
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                <Border Name="Border" BorderThickness="1" BorderBrush="Gray" Background="{StaticResource SelectedBrush}"
					                                            SnapsToDevicePixels="True">
                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridCell_PreviewMouseLeftButtonDownShipRec"></EventSetter>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="PO NUMBER" Binding="{Binding PoNumber}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="INDEX" Binding="{Binding Polnenum}" Width="50" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="SOP NUMBER" Binding="{Binding SopNumber}" Width="80" IsReadOnly="True">

                </DataGridTextColumn>
                <DataGridTextColumn Header="JOB NUMBER" Binding="{Binding JobNumber}" Width="90" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="MANUFACTURER" Binding="{Binding VendorName}" Width="230" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="ITEM NUMBER" Binding="{Binding ItemNumber}" Width="120" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="ITEM DESCRIPTION" Binding="{Binding ItemDescription}" Width="500" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="ORIGINAL ITEM ORDER QUANTITY" Binding="{Binding QtyOrdFromGp}" Width="60" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="QUANTITY RECEIVED" Binding="{Binding QtyRecForGp}" Width="60" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="QUANTITY REMAINING IN RACKS" Binding="{Binding QtyRemainingOnRec}" Width="60" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="QUANTITY TO SHIP" Width="60" Binding="{Binding UiQuantityToTransfer, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False" HeaderStyle="{StaticResource SelectableColumn}" >

                </DataGridTextColumn>
                <DataGridTemplateColumn Header="COMMIT QUANTITY" Width="60" HeaderStyle="{StaticResource SelectableColumn}" >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="X"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="DATE RECEIVED" Binding="{Binding DateReceived, StringFormat=\{0:dd \MMM \yyyy\}}" Width="100" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" Width="100" IsReadOnly="True" >

                </DataGridTextColumn>
                <DataGridTextColumn Header="COMMENTS" Binding="{Binding Comments}" Width="200" IsReadOnly="True" >

                </DataGridTextColumn>
            </DataGrid.Columns>
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Margin" Value="0,0,0,5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <StackPanel Background="#FF706F6F" DataContext="{Binding Items}">
                                            <DockPanel HorizontalAlignment="Stretch" Margin="0 5px 0 5px">
                                                <TextBlock Foreground="White" FontWeight="Bold" Margin="0 0 20px 0" TextWrapping="NoWrap">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} {1}">
                                                            <Binding Path="PoNumber" />
                                                            <Binding Path="Polnenum" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DockPanel>
                                            <ItemsPresenter />
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>
        </DataGrid>
    </Grid>
</Window>
