<Window x:Class="PM_Project_Tracking.WhRecsBlankLinesShippingMemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PM_Project_Tracking"
        mc:Ignorable="d"
        Title="WhRecsBlankLinesShippingMemo" Height="120" Width="200">
    <Grid Background="#FF494949">
        <StackPanel Orientation="Vertical">
            <TextBox Name="TB_LineCount" Margin="10,10,0,0"  Width="50" HorizontalAlignment="Center" HorizontalContentAlignment="Center" FontSize="16" Padding="0"
                     Text="{Binding Path=LineCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Name="BTN_Confirm" Content="CONFIRM" Margin="10,10,0,0" HorizontalAlignment="Center" Height="30" Width="100" Click="BTN_Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
